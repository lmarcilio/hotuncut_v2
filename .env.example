# VITE_SUPABASE_URL: Your Supabase project URL (Client-side).
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase anonymous key (Client-side).
VITE_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Required for server-side operations (Backend).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NEXANO_WEBHOOK_TOKEN: Token esperado no header x-nexano-token (ou x-webhook-token).
NEXANO_WEBHOOK_TOKEN="dsuxblan"
